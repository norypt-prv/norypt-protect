        <intent android:action="android.intent.action.VIEW"
                android:targetPackage="com.norypt.protect.debug"
                android:targetClass="com.norypt.protect.MainActivity">
            <extra android:name="action" android:value="wipe"/>
        </intent>
    </shortcut>
